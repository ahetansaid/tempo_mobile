# ---- Base de données (PostgreSQL 16 + PostGIS) ----
DATABASE_URL=postgresql://user:pass@host:5432/tempo

# ---- App ----
APP_URL=https://tempo.bj

# ---- Better Auth ----
BETTER_AUTH_SECRET=change-moi-32-caracteres-aleatoires
BETTER_AUTH_URL=https://tempo.bj

# ---- Cloudflare R2 (stockage photos) ----
R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=tempo-photos
R2_PUBLIC_URL=https://cdn.tempo.bj

# ---- Firebase Cloud Messaging (push) ----
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ---- Cron (secret partagé avec Vercel Cron) ----
CRON_SECRET=change-moi-secret-cron
